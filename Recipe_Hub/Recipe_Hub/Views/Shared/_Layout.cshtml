@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Basic metadata -->
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    
    <!-- Dynamic page title -->
    <title>@ViewData["Title"] - Recipe_Hub</title>
    
    <!-- CSS files -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/Recipe_Hub.styles.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/recipes.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/statistics.css"/>
    <link rel="stylesheet" href="~/css/add_recipe.css"/>
    <link rel="stylesheet" href="~/css/recipe_details.css"/>
    
    <!-- External icon libraries -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body class="@ViewData["BodyClass"]">

<header>
    <nav class="navbar navbar-expand-lg navbar-light bg-white custom-nav shadow-nav">
        <div class="container d-flex justify-content-between align-items-center">

            <!-- Logo + brand -->
            <a class="navbar-brand d-flex align-items-center ms-auto" asp-controller="Home" asp-action="Index">
                <img src="~/Resources/Images/logo.png" class="nav-logo" alt="Logo">
                <span class="brand-text ms-2">Dishlly</span>
            </a>

            <!-- Mobile menu toggle -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Navigation links -->
            <div class="collapse navbar-collapse justify-content-end" id="mainNav">

                <ul class="navbar-nav align-items-center me-3">

                    <li class="nav-item">
                        <a class="nav-link nav-anim" asp-controller="Home" asp-action="Index">
                            <i class="fa-solid fa-house me-2"></i> Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-anim" asp-controller="Recipes" asp-action="Index">
                            <i class="fa-solid fa-book-open me-2"></i> Recipes
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-anim" asp-controller="Recipes" asp-action="Create">
                            <i class="fa-solid fa-circle-plus me-2"></i> Create Recipe
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-anim" asp-controller="Statistics" asp-action="Index">
                            <i class="fa-solid fa-chart-line me-2"></i> Statistics
                        </a>
                    </li>

                </ul>

                @if (User.Identity.IsAuthenticated)
                {
                    <div class="dropdown">
                        <!-- Extract first letter of username for avatar -->
                        @{
                            var username = User.Identity.Name;
                            var initial = !string.IsNullOrEmpty(username) ? username[0].ToString().ToUpper() : "?";
                        }

                        <a class="d-flex align-items-center profile-btn" href="#" data-bs-toggle="dropdown">
                            <div class="profile-initial">@initial</div>
                            <span class="profile-name">@username</span>
                        </a>

                        <!-- Dropdown menu -->
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <form asp-area="Identity"
                                      asp-page="/Account/Logout"
                                      asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                                      class="m-0 p-0">

                                    <button type="submit" class="dropdown-item">
                                        Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                { 
                    <!-- Login/Register button -->
                  <a class="btn login-btn ms-3" asp-area="Identity" asp-page="/Account/Login"> Login / Register </a>
                }

            </div>
        </div>
    </nav>
</header>

<main role="main">
    @RenderBody()  <!-- Render the content of each page -->
</main>

<footer class="site-footer">
    <div class="footer-container">

        <!-- About section -->
        <div class="footer-section footer-about">
            <img src="/Resources/Images/logo.png" class="footer-logo" alt="Logo" />
            <p class="footer-about-text">
                Chef’s Network is a social cooking platform where food lovers and professionals
                share recipes, discover new ideas, and inspire each other every day.
            </p>

            <div class="footer-about-icons">
                <i class="fa-solid fa-utensils"></i>
                <i class="fa-solid fa-seedling"></i>
                <i class="fa-solid fa-fire-burner"></i>
            </div>
        </div>

        <!-- Quick Links -->
        <div class="footer-section">
            <h4><i class="fa-solid fa-compass"></i> Quick Links</h4>
            <ul class="footer-links">
                <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li><a asp-controller="Recipes" asp-action="Index">Recipes</a></li>
                <li><a asp-controller="Recipes" asp-action="Create">Create Recipe</a></li>
                <li><a asp-area="Identity" asp-page="/Account/Login"> Login</a></li>
                <li><a asp-area="Identity" asp-page="/Account/Register"> Register</a></li>
            </ul>
        </div>

        <!-- Explore section -->
        <div class="footer-section">
            <h4><i class="fa-solid fa-chart-simple"></i> Explore</h4>
            <ul class="footer-links">
                <li><a asp-controller="Statistics" asp-action="Index" asp-route-section="top">Top 3 Most Liked Recipes</a></li>
                <li><a asp-controller="Statistics" asp-action="Index" asp-route-section="users">Most Active Users</a></li>
                <li><a asp-controller="Statistics" asp-action="Index" asp-route-section="categories">Popular Categories</a></li>
            </ul>
        </div>

        <!-- Feedback section -->
        <div class="footer-section footer-feedback">
            <h4><i class="fa-solid fa-envelope"></i> Feedback</h4>

            <form method="post" asp-controller="Home" asp-action="SendFeedback" class="footer-feedback-form">
                <textarea name="message" placeholder="Your message..." required></textarea>
                <button type="submit"><i class="fa-solid fa-paper-plane"></i> Send</button>
            </form>

            <h4 class="footer-social-title"><i class="fa-solid fa-mobile-screen"></i> Connect With Us</h4>
            <div class="footer-socials">
                <a href="#"><i class="fa-brands fa-facebook"></i></a>
                <a href="#"><i class="fa-brands fa-instagram"></i></a>
                <a href="#"><i class="fa-brands fa-tiktok"></i></a>
                <a href="#"><i class="fa-brands fa-youtube"></i></a>
            </div>
        </div>

    </div>

    <div class="footer-bottom">
        <p>© @DateTime.Now.Year Chef’s Network — All rights reserved.</p>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)

<script>
    //Adjust hero section height based on navbar height
    function fixHeroHeight() {
        const nav = document.querySelector("header nav");
        const hero = document.querySelector(".video-hero");

        if (!nav || !hero) return;

        const navHeight = nav.offsetHeight;
        hero.style.height = (window.innerHeight - navHeight) + "px";
    }

    window.addEventListener("load", fixHeroHeight);
    window.addEventListener("resize", fixHeroHeight);
</script>
</body>
</html>
