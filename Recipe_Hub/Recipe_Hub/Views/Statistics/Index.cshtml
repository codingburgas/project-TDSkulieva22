@model Recipe_Hub.Models.ViewModels.StatisticsViewModel

<div class="stats-wrapper">
    
    <!-- Page title section -->
    <div class="stats-title-wrapper">
        <span class="line"></span>

        <h1 class="page-main-title">
            <i class="fa-solid fa-chart-pie stats-icon"></i>
            Platform Statistics
        </h1>

        <span class="line"></span>
    </div>

    <!-- Top 3 Recipes Section -->
    <section class="stats-section">
        <div class="recipes-container">
            <h2 class="section-heading">Top 3 Recipes of the Month</h2>
            <hr/>
            <div class="recipes-grid">
                @foreach (var recipe in Model.TopRecipes)
                {
                    <div class="recipe-card">
                        
                        <!-- Recipe main image -->
                        <img src="@recipe.MainImagePath" class="recipe-img"/>

                        <div class="recipe-info">
                            <h3 class="recipe-title">@recipe.Title</h3>

                            <p class="recipe-author">
                                <i class="fa-solid fa-user user-icon"></i>
                                <span class="author-name">@recipe.User.UserName</span>
                                <span class="recipe-date">@recipe.CreatedAt.ToString("dd MMM yyyy",
                                                              System.Globalization.CultureInfo.InvariantCulture)</span>
                            </p>

                            <div class="recipe-meta">
                                <span class="recipe-fans">
                                    <i class="fa-solid fa-comment meta-icon"></i> @recipe.Comments.Count
                                </span>
                                <span class="recipe-likes">
                                    <i class="fa-solid fa-heart meta-icon"></i> @recipe.Likes.Count
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <hr/>
        </div>
    </section>

    <!-- Most Active Users Section -->
    <section class="stats-section">
        <div class="users-container">
            <h2 class="section-heading">Most Active Users</h2>

            <div class="users-list">
                @foreach (var user in Model.MostActiveUsers)
                {
                    <div class="user-row">

                        <!-- User avatar + info -->
                        <div class="user-left">
                            
                            <!-- Avatar with first letter of username -->
                            <div class="user-avatar">
                                @user.UserName.Substring(0, 1).ToUpper()
                            </div>

                            <div class="user-info">
                                <!-- Username and recipe count -->
                                <div class="user-header">
                                    <h3 class="user-name">@user.UserName</h3>
                                    <span class="user-recipes">(@user.RecipeCount recipes)</span>
                                </div>

                                <!-- Likes, comments, top recipe -->
                                <div class="user-stats-inline">
                                    <span><i class="fa-solid fa-heart"></i> @user.TotalLikes likes</span>
                                    <span><i class="fa-solid fa-comment"></i> @user.TotalComments comments</span>
                                    <span><i class="fa-solid fa-star"></i> @user.TopRecipeTitle (@user.TopRecipeLikes likes)</span>
                                </div>
                            </div>
                        </div>

                        <!-- Activity score box -->
                        <div class="activity-box">
                            @user.ActivityScore
                        </div>
                    </div>

                    <hr class="user-divider"/>
                }
            </div>
        </div>
    </section>

    <!-- Category Popularity Section -->
    <section class="stats-section">
        <div class="category-container">

            <h2 class="section-heading">
                <i class="fa-solid fa-chart-simple"></i> Category Popularity
            </h2>

            <div class="category-chart">
                @foreach (var cat in Model.CategoryPopularity)
                {
                    //Calculate percentage for each category
                    var percentage = (int)((double)cat.Value /
                        Model.CategoryPopularity.Sum(x => x.Value) * 100);

                    <div class="category-row">
                        <span class="cat-label">@cat.Key</span>

                        <!-- Bar chart -->
                        <div class="cat-bar">
                            <div class="cat-fill" style="width:@percentage%"></div>
                        </div>

                        <span class="cat-percent">@percentage%</span>
                    </div>
                }
            </div>

        </div>
    </section>
</div>
