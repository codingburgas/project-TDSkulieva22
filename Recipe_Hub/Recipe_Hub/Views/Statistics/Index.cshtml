@model Recipe_Hub.Models.ViewModels.StatisticsViewModel

<div class="container py-5">
    <h1 class="text-center mb-5 fw-bold">Platform Statistics</h1>
    <h3 class="fw-semibold mb-3">Top 3 Recipes of the Month</h3>

    <div class="row g-4 mb-5">
        @foreach (var recipe in Model.TopRecipes)
        {
            <div class="col-md-4">
                <div class="card shadow border-0 h-100">
                    <img src="@recipe.MainImagePath" class="card-img-top" style="height: 180px; object-fit: cover;" />

                    <div class="card-body">
                        <h5 class="fw-bold">@recipe.Title</h5>

                        <div class="d-flex justify-content-between mt-3">
                            <span class="text-muted">@recipe.Comments.Count fans</span>
                            <span class="text-danger fw-bold">❤️ @recipe.Likes.Count</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <hr class="my-5" />

    <h3 class="fw-semibold mb-3">Most Active Users</h3>

    <div class="row g-4 mb-5">
        @foreach (var user in Model.MostActiveUsers)
        {
            <div class="col-md-4">
                <div class="card shadow-sm border-0 p-3">
                    <div class="d-flex align-items-center">
                        <div class="rounded-circle bg-secondary text-white d-flex justify-content-center align-items-center"
                             style="width: 55px; height: 55px; font-size: 22px;">
                            @user.UserName.Substring(0,1).ToUpper()
                        </div>

                        <div class="ms-3">
                            <h5 class="fw-bold mb-1">@user.UserName</h5>
                            <p class="text-muted mb-1">@user.RecipeCount recipes</p>
                        </div>
                    </div>

                    <div class="mt-3 p-3 bg-light rounded">
                        <p class="small text-muted mb-0">Activity Badge</p>
                        <p class="fw-semibold">Top Contributor</p>
                    </div>
                </div>
            </div>
        }
    </div>

    <hr class="my-5" />

    <h3 class="fw-semibold mb-3">Category Popularity</h3>

    <div class="row">
        @foreach (var cat in Model.CategoryPopularity)
        {
            var percentage = (int)((double)cat.Value /
                Model.CategoryPopularity.Sum(x => x.Value) * 100);

            <div class="col-md-6 mb-4">
                <div class="d-flex justify-content-between">
                    <span class="fw-semibold">@cat.Key</span>
                    <span>@percentage%</span>
                </div>

                <div class="progress" style="height: 12px;">
                    <div class="progress-bar bg-warning" role="progressbar"
                         style="width:@percentage%"></div>
                </div>
            </div>
        }
    </div>

    <div class="text-center mt-4">
        <a class="btn btn-warning px-4 py-2 fw-semibold">See More Recipes</a>
    </div>

</div>