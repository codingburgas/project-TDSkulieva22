@model Recipe_Hub.Models.ViewModels.CreateRecipeViewModel
@{
    Layout = "_Layout";
}

<div class="recipe-form-container">
    <h2 class="form-title">Edit Recipe</h2>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <div class="row gx-4 gy-4 first-row">
            <div class="col-lg-4">
                <div class="card section-basic">
                    <div class="card-header">
                        <i class="bi bi-pencil-square"></i>
                        Basic Information
                    </div>

                    <div class="card-body">

                        <div class="form-row-2">
                            <div class="form-group">
                                <label asp-for="Title"></label>
                                <input asp-for="Title" class="form-control" />
                            </div>

                            <div class="form-group">
                                <label asp-for="CookingTime"></label>
                                <input asp-for="CookingTime" class="form-control" />
                            </div>
                        </div>

                        <div class="form-row-2">
                            <div class="form-group">
                                <label asp-for="CategoryId"></label>
                                <select asp-for="CategoryId" class="form-select" asp-items="Model.Categories"></select>
                            </div>

                            <div class="form-group">
                                <label asp-for="Difficulty"></label>
                                <select asp-for="Difficulty" class="form-select">
                                    <option value="1">Easy</option>
                                    <option value="2">Medium</option>
                                    <option value="3">Hard</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-group mt-3">
                            <label asp-for="Description"></label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>

                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card section-ingredients">
                    <div class="card-header">
                        <i class="bi bi-basket"></i>
                        Ingredients
                    </div>

                    <div class="card-body">

                        <div id="ingredients-container">
                            @for (int i = 0; i < Model.IngredientIds.Count; i++)
                            {
                                <div class="ingredient-row d-flex flex-wrap gap-2 mb-2">
                                    <select asp-for="IngredientIds[i]" class="form-select flex-grow-1" asp-items="Model.Ingredients"></select>
                                    <input asp-for="Quantities[i]" class="form-control flex-grow-1" placeholder="Quantity" />
                                    <button type="button" class="remove-ingredient">✖</button>
                                </div>
                            }
                        </div>

                        <button type="button" id="add-ingredient" class="btn add-ingredient-btn">+ Add Ingredient</button>

                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card section-steps">
                    <div class="card-header">
                        <i class="bi bi-list-check"></i>
                        Steps
                    </div>

                    <div class="card-body">

                        <div id="steps-container">
                            @for (int i = 0; i < Model.Steps.Count; i++)
                            {
                                <div class="step-row mb-3">
                                    <textarea asp-for="Steps[i]" class="form-control" rows="3"></textarea>
                                    <button type="button" class="remove-step mt-2">✖</button>
                                </div>
                            }
                        </div>

                        <button type="button" id="add-step" class="btn add-step-btn">+ Add Step</button>

                    </div>
                </div>
            </div>

        </div>
        <div class="row gx-4 gy-4 second-row mt-2">

            <div class="col-lg-12">
                <div class="card section-images wide-images-box">
                    <div class="card-header">
                        <i class="bi bi-camera"></i>
                        Images
                    </div>

                    <div class="card-body">

                        <div class="form-group mb-3">
                            <label>Replace Main Image (optional)</label>
                            <input type="file" asp-for="MainImage" class="form-control" />
                        </div>

                        <div class="form-group mb-3">
                            <label>Add More Gallery Images (optional)</label>
                            <input type="file" asp-for="GalleryImages" class="form-control" multiple />
                        </div>

                    </div>
                </div>
            </div>

        </div>

        <div class="submit-wrapper mt-4">
            <button type="submit" class="btn-create">Save Changes</button>
        </div>

    </form>
</div>

@section Scripts {
    <script>
        document.getElementById("add-ingredient").addEventListener("click", function () {
            const container = document.getElementById("ingredients-container");
            const index = container.children.length;

            const row = document.createElement("div");
            row.className = "ingredient-row d-flex flex-wrap gap-2 mb-2";

            row.innerHTML = `
                <select name="IngredientIds[${index}]" class="form-select flex-grow-1">
                    ${document.querySelector("select[name='IngredientIds[0]']").innerHTML}
                </select>
                <input name="Quantities[${index}]" class="form-control flex-grow-1" placeholder="Quantity" />
                <button type="button" class="remove-ingredient">✖</button>
            `;

            container.appendChild(row);
        });

        document.addEventListener("click", function (e) {
            if (e.target.classList.contains("remove-ingredient")) {
                e.target.closest(".ingredient-row").remove();
            }
        });
        document.getElementById("add-step").addEventListener("click", function () {
            const container = document.getElementById("steps-container");
            const index = container.children.length;

            const row = document.createElement("div");
            row.className = "step-row mb-3";

            row.innerHTML = `
                <textarea name="Steps[${index}]" class="form-control" rows="3"></textarea>
                <button type="button" class="remove-step mt-2">✖</button>
            `;

            container.appendChild(row);
        });

        document.addEventListener("click", function (e) {
            if (e.target.classList.contains("remove-step")) {
                e.target.closest(".step-row").remove();
            }
        });
    </script>
}