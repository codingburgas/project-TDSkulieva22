@model Recipe_Hub.Models.ViewModels.CreateRecipeViewModel

<h2>Edit Recipe</h2>

<form asp-action="Edit" method="post" enctype="multipart/form-data">

    <div class="form-group">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CookingTime"></label>
        <input asp-for="CookingTime" class="form-control" />
        <span asp-validation-for="CookingTime" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Difficulty"></label>
        <select asp-for="Difficulty" class="form-control">
            <option>Easy</option>
            <option>Medium</option>
            <option>Hard</option>
        </select>
        <span asp-validation-for="Difficulty" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CategoryId">Category</label>
        <select asp-for="CategoryId" asp-items="Model.Categories" class="form-control"></select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <h4>Ingredients</h4>
    <div id="ingredients-list">
        @for (int i = 0; i < Model.IngredientIds.Count; i++)
        {
            <div class="form-group ingredient-row d-flex gap-2">
                <select asp-for="IngredientIds[i]" class="form-control" asp-items="Model.Ingredients"></select>
                <input asp-for="Quantities[i]" class="form-control mt-1" placeholder="Quantity" />
                <button type="button" class="no-bg-btn" onclick="removeIngredient(this)">✖</button>
            </div>
        }
    </div>
    <button type="button" class="btn btn-success mb-3" onclick="addIngredient()">Add Ingredient</button>

    <h4>Steps</h4>
    <div id="steps-list">
        @for (int i = 0; i < Model.Steps.Count; i++)
        {
            <div class="form-group step-row">
                <div class="d-flex gap-2">
                    <textarea asp-for="Steps[i]" class="form-control"></textarea>
                    <button type="button" class="no-bg-btn" onclick="removeStep(this)">✖</button>
                </div>
            </div>
        }
    </div>
    <button type="button" class="btn btn-success mb-3" onclick="addStep()">Add Step</button>

    <h4>Main Image</h4>
    <div class="form-group">
        <input type="file" asp-for="MainImage" class="form-control" />
    </div>

    <h4>Gallery Images (optional)</h4>
    <div class="form-group">
        <input type="file" asp-for="GalleryImages" class="form-control" multiple />
    </div>

    <button type="submit" class="btn btn-primary mt-3">Save Changes</button>
    <a asp-action="Details" asp-route-id="@ViewContext.RouteData.Values["id"]" class="btn btn-secondary mt-3">Cancel</a>

</form>

@section Scripts {
    <script>
        function addIngredient() {
            const container = document.getElementById("ingredients-list");
            const index = container.querySelectorAll(".ingredient-row").length;

            const select = document.createElement("select");
            select.className = "form-control";
            select.name = `IngredientIds[${index}]`;

            const options = document.querySelector("select[name='IngredientIds[0]']").options;
            for (let opt of options) {
                const newOpt = document.createElement("option");
                newOpt.value = opt.value;
                newOpt.textContent = opt.textContent;
                select.appendChild(newOpt);
            }

            const qty = document.createElement("input");
            qty.className = "form-control mt-1";
            qty.name = `Quantities[${index}]`;
            qty.placeholder = "Quantity";

            const removeBtn = document.createElement("button");
            removeBtn.type = "button";
            removeBtn.className = "btn btn-danger";
            removeBtn.textContent = "✖";
            removeBtn.onclick = () => removeIngredient(removeBtn);

            const row = document.createElement("div");
            row.className = "form-group ingredient-row d-flex gap-2";

            row.appendChild(select);
            row.appendChild(qty);
            row.appendChild(removeBtn);

            container.appendChild(row);
        }
    
    function removeIngredient(btn) {
        btn.closest(".ingredient-row").remove();
        reindexIngredients();
    }

    function reindexIngredients() {
        const rows = document.querySelectorAll(".ingredient-row");
        rows.forEach((row, i) => {
            row.querySelector("select").name = `IngredientIds[${i}]`;
            row.querySelector("input").name = `Quantities[${i}]`;
        });
    }
    
    function addStep() {
        const container = document.getElementById("steps-list");
        const index = container.children.length;

        const textarea = document.createElement("textarea");
        textarea.name = `Steps[${index}]`;
        textarea.className = "form-control";

        const removeBtn = document.createElement("button");
        removeBtn.type = "button";
        removeBtn.className = "btn btn-danger";
        removeBtn.textContent = "✖";
        removeBtn.onclick = () => removeStep(removeBtn);

        const wrapper = document.createElement("div");
        wrapper.className = "form-group step-row";

        const row = document.createElement("div");
        row.className = "d-flex gap-2";

        row.appendChild(textarea);
        row.appendChild(removeBtn);

        wrapper.appendChild(row);
        container.appendChild(wrapper);
    }

    function removeStep(btn) {
        btn.closest(".step-row").remove();
        reindexSteps();
    }

    function reindexSteps() {
        const rows = document.querySelectorAll(".step-row");
        rows.forEach((row, i) => {
            const textarea = row.querySelector("textarea");
            textarea.name = `Steps[${i}]`;
        });
    }
</script>
}