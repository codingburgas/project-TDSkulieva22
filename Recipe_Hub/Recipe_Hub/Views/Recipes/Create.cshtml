@model Recipe_Hub.Models.ViewModels.CreateRecipeViewModel
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}
<h2>Create Recipe</h2>
<form asp-action="Create" method="post" enctype="multipart/form-data">

    <!-- Title -->
    <div class="form-group">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <!-- Description -->
    <div class="form-group">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <!-- Category -->
    <div class="form-group">
        <label asp-for="CategoryId"></label>
        <select asp-for="CategoryId" class="form-control" asp-items="Model.Categories">
            <option value="">-- Select category --</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <!-- Cooking Time -->
    <div class="form-group">
        <label asp-for="CookingTime"></label>
        <input asp-for="CookingTime" class="form-control" />
        <span asp-validation-for="CookingTime" class="text-danger"></span>
    </div>

    <!-- Difficulty -->
    <div class="form-group">
        <label asp-for="Difficulty"></label>
        <select asp-for="Difficulty" class="form-control">
            <option value="1">Easy</option>
            <option value="2">Medium</option>
            <option value="3">Hard</option>
        </select>
        <span asp-validation-for="Difficulty" class="text-danger"></span>
    </div>

    <!-- Ingredients -->
    <h4>Ingredients</h4>
    <div id="ingredients-container">
        <div class="ingredient-row">
            <select name="IngredientIds[0]" class="form-control" style="width: 40%; display:inline-block"
                    asp-items="Model.Ingredients"></select>

            <input name="Quantities[0]" class="form-control" style="width: 40%; display:inline-block"
                   placeholder="Quantity (e.g. 200g)" />

            <button type="button" class="btn btn-danger remove-ingredient">X</button>
        </div>
    </div>

    <button type="button" id="add-ingredient" class="btn btn-secondary mt-2">Add Ingredient</button>

    <!-- Steps in recipe -->
    <h4 class="mt-4">Steps</h4>
    <div id="steps-container">
        <div class="step-row">
            <textarea name="Steps[0]" class="form-control" placeholder="Describe step..."></textarea>
            <button type="button" class="btn btn-danger remove-step mt-1">X</button>
        </div>
    </div>

    <button type="button" id="add-step" class="btn btn-secondary mt-2">Add Step</button>

    <!-- Images -->
    <h4 class="mt-4">Images</h4>

    <div class="form-group">
        <label>Main Image</label>
        <input type="file" name="MainImage" class="form-control" />
    </div>

    <div class="form-group">
        <label>Gallery Images</label>
        <input type="file" name="GalleryImages" class="form-control" multiple />
    </div>

    <button type="submit" class="btn btn-primary mt-3">Create Recipe</button>
</form>

@section Scripts {
    <script>
    // Add Ingredient
    document.getElementById("add-ingredient").addEventListener("click", function () {
        const container = document.getElementById("ingredients-container");
        const index = container.querySelectorAll(".ingredient-row").length;

        const row = document.createElement("div");
        row.classList.add("ingredient-row");

        row.innerHTML = `
            <select name="IngredientIds[${index}]" class="form-control" style="width: 40%; display:inline-block">
                @foreach (var item in Model.Ingredients)
                {
                    <option value="@item.Value">@item.Text</option>
                }
            </select>

            <input name="Quantities[${index}]" class="form-control" style="width: 40%; display:inline-block"
                   placeholder="Quantity (e.g. 200g)" />

            <button type="button" class="btn btn-danger remove-ingredient">X</button>
        `;

        container.appendChild(row);
    });

    // Remove Ingredient
    document.addEventListener("click", function (e) {
        if (e.target.classList.contains("remove-ingredient")) {
            e.target.parentElement.remove();
        }
    });

    // Add Step
    document.getElementById("add-step").addEventListener("click", function () {
        const container = document.getElementById("steps-container");
        const index = container.querySelectorAll(".step-row").length;

        const row = document.createElement("div");
        row.classList.add("step-row");

        row.innerHTML = `
            <textarea name="Steps[${index}]" class="form-control" placeholder="Describe step..."></textarea>
            <button type="button" class="btn btn-danger remove-step mt-1">X</button>
        `;

        container.appendChild(row);
    });

    // Remove Step
    document.addEventListener("click", function (e) {
        if (e.target.classList.contains("remove-step")) {
            e.target.parentElement.remove();
        }
    });
</script>
}