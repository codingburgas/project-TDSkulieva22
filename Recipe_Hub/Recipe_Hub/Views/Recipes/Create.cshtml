@model Recipe_Hub.Models.ViewModels.CreateRecipeViewModel
@{
    Layout = "_Layout";  //Use the main site layout
}

<!-- Display error message from TempData -->
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}
<div class="recipe-form-container">
    <h2 class="form-title">Create Recipe</h2>

    <!-- Main recipe creation form -->
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="row gx-4 gy-4 first-row">
            <div class="col-lg-4">
                <div class="card section-basic">
                    <div class="card-header">
                        <i class="bi bi-pencil-square"></i>
                        Basic Information
                    </div>

                    <div class="card-body">

                        <!-- Title + Cooking Time -->
                        <div class="form-row-2">
                            <div class="form-group">
                                <label asp-for="Title"></label>
                                <input asp-for="Title" class="form-control" />
                            </div>

                            <div class="form-group">
                                <label asp-for="CookingTime"></label>
                                <input asp-for="CookingTime" class="form-control" placeholder="Minutes" />
                            </div>
                        </div>
                        
                        <!-- Category + Difficulty -->
                        <div class="form-row-2">
                            <div class="form-group">
                                <label asp-for="CategoryId"></label>
                                <select asp-for="CategoryId" class="form-select" asp-items="Model.Categories">
                                    <option value="">-- Select --</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label asp-for="Difficulty"></label>
                                <select asp-for="Difficulty" class="form-select">
                                    <option value="1">Easy</option>
                                    <option value="2">Medium</option>
                                    <option value="3">Hard</option>
                                </select>
                            </div>
                        </div>

                        <!-- Description -->
                        <div class="form-group mt-3">
                            <label asp-for="Description"></label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card section-ingredients">
                    <div class="card-header">
                        <i class="bi bi-basket"></i>
                        Ingredients
                    </div>

                    <div class="card-body">

                        <!-- Dynamic ingredient rows -->
                        <div id="ingredients-container">
                            <div class="ingredient-row d-flex flex-wrap gap-2 mb-2">
                                <select name="IngredientIds[0]" class="form-select flex-grow-1" asp-items="Model.Ingredients"></select>
                                <input name="Quantities[0]" class="form-control flex-grow-1" placeholder="Quantity (e.g. 200g)" />
                                <button type="button" class="btn btn-danger remove-ingredient">✖</button>
                            </div>
                        </div>

                        <!-- Add new ingredient row -->
                        <button type="button" id="add-ingredient" class="btn add-ingredient-btn">+ Add Ingredient</button>

                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card section-steps">
                    <div class="card-header">
                        <i class="bi bi-list-check"></i>
                        Steps
                    </div>

                    <div class="card-body">
                        
                        <!-- Dynamic step rows -->
                        <div id="steps-container">
                            <div class="step-row mb-3">
                                <textarea name="Steps[0]" class="form-control" rows="3" placeholder="Describe step..."></textarea>
                                <button type="button" class="btn btn-danger remove-step mt-2">✖</button>
                            </div>
                        </div>

                        <!-- Add new step row -->
                        <button type="button" id="add-step" class="btn add-step-btn">+ Add Step</button>

                    </div>
                </div>
            </div>

        </div>

        <div class="row gx-4 gy-4 second-row mt-2">

            <div class="col-lg-12">
                <div class="card section-images wide-images-box">
                    <div class="card-header">
                        <i class="bi bi-camera"></i>
                        Images
                    </div>

                    <div class="card-body">

                        <!-- Main image upload -->
                        <div class="form-group mb-3">
                            <label>Main Image</label>
                            <input type="file" name="MainImage" class="form-control" />
                        </div>

                        <!-- Gallery images upload -->
                        <div class="form-group mb-3">
                            <label>Gallery Images</label>
                            <input type="file" name="GalleryImages" class="form-control" multiple />
                        </div>

                    </div>
                </div>
            </div>

        </div>
        <div class="submit-wrapper mt-4">
            <button type="submit" class="btn-create">
                <i class="fa-solid fa-plus"></i>
                Create Recipe
            </button>
        </div>

    </form>
</div>

@section Scripts {
    <script>
        //Add new ingredient row
        document.getElementById("add-ingredient").addEventListener("click", function () {
            const container = document.getElementById("ingredients-container");
            const index = container.children.length;

            const row = document.createElement("div");
            row.className = "ingredient-row d-flex flex-wrap gap-2 mb-2";

            //Copy first ingredient dropdown options
            row.innerHTML = `
                <select name="IngredientIds[${index}]" class="form-select flex-grow-1">
                    ${document.querySelector("select[name='IngredientIds[0]']").innerHTML}
                </select>
                <input name="Quantities[${index}]" class="form-control flex-grow-1" placeholder="Quantity" />
                <button type="button" class="btn btn-danger remove-ingredient">✖</button>
            `;

            container.appendChild(row);
        });

        //Remove ingredient row
        document.addEventListener("click", function (e) {
            if (e.target.classList.contains("remove-ingredient")) {
                e.target.closest(".ingredient-row").remove();
            }
        });

        //Add new step row
        document.getElementById("add-step").addEventListener("click", function () {
            const container = document.getElementById("steps-container");
            const index = container.children.length;

            const row = document.createElement("div");
            row.className = "step-row mb-3";

            row.innerHTML = `
                <textarea name="Steps[${index}]" class="form-control" rows="3" placeholder="Describe step..."></textarea>
                <button type="button" class="btn btn-danger remove-step mt-2">✖</button>
            `;

            container.appendChild(row);
        });

        //Remove step row
        document.addEventListener("click", function (e) {
            if (e.target.classList.contains("remove-step")) {
                e.target.closest(".step-row").remove();
            }
        });
</script>
}