@model Recipe_Hub.Models.Recipe
@using System.Security.Claims

@{
    // Get current logged-in user ID
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    bool userLiked = Model.Likes.Any(l => l.UserId == userId);
}

<div class="recipe-details-page">
    <div class="recipe-main-box">

        <!-- Main recipe image -->
        <img src="@Model.MainImagePath" alt="@Model.Title" class="recipe-main-img" />

        <div class="recipe-main-info">
            <div class="title-with-actions">

                <h1 class="recipe-title">@Model.Title</h1>

                @using Microsoft.AspNetCore.Identity
                @inject UserManager<IdentityUser> UserManager

                @{
                    //Determine if current user is the recipe owner or an admin
                    var currentUserId = UserManager.GetUserId(User);
                    bool isOwner = Model.UserId == currentUserId;
                    bool isAdmin = User.IsInRole("Admin");
                }

                @if (isOwner || isAdmin)
                {
                    <div class="edit-delete-inline">
                        <!-- Edit button -->
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="edit-btn-inline">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </a>

                        <!-- Delete button -->
                        <button class="delete-btn-inline" data-bs-toggle="modal" data-bs-target="#deleteModal">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                }

            </div>
            <div class="title-subrow">

                <!-- Creation date -->
                <span class="recipe-date">
                    <i class="fa-regular fa-calendar"></i>
                    @Model.CreatedAt.ToString("dd MMM yyyy")
                </span>

                <!-- Like button -->
                <button id="likeBtn" class="recipe-like-btn @(userLiked ? "liked" : "")">
                    <i id="heartIcon" class="@(userLiked ? "fa-solid fa-heart" : "fa-regular fa-heart")"></i>
                    <span>Like</span>
                    <span id="likeCount">@Model.Likes.Count</span>
                </button>

            </div>
            <div class="recipe-meta-line">
                <span><i class="fa-solid fa-user"></i> @Model.User?.UserName</span>
                <span><i class="fa-solid fa-utensils"></i> @Model.Category?.Name</span>
                <span><i class="fa-solid fa-fire"></i> @Model.Difficulty</span>
                <span><i class="fa-solid fa-clock"></i> @Model.CookingTime мин</span>
            </div>

            <p class="recipe-description">@Html.Raw(Model.Description)</p>

        </div>

    </div>
    <div class="second-row-wrapper">

    <div class="section-box ingredients-box">
        <h2 class="section-title">Ingredients</h2>
        <ul class="ingredients-list">
            @foreach (var ri in Model.RecipeIngredients)
            {
                <li>
                    <i class="fa-solid fa-circle-check ingredient-icon"></i>
                    <span class="ingredient-name">@ri.Ingredient.Name</span>
                    <span class="ingredient-qty">@ri.Quantity</span>
                </li>
            }
        </ul>
    </div>

    <div class="section-box steps-box">
        <h2 class="section-title">Steps</h2>
        <ol class="steps-list">
            @foreach (var step in Model.Steps.OrderBy(s => s.StepNumber))
            {
                <li>@Html.Raw(step.Description)</li>
            }
        </ol>
    </div>

    <div class="section-box comments-box">
        <h2 class="section-title">Comments (@Model.Comments.Count)</h2>

        @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
        {
            <div class="comment-item">

                @{
                    var isCommentOwner = comment.UserId == userId;
                    var isCommentAdmin = User.IsInRole("Admin");
                }

                @if (isCommentOwner || isCommentAdmin)
                {
                    <!-- Delete comment form -->
                    <form method="post"
                          asp-controller="Comment"
                          asp-action="Delete"
                          asp-route-id="@comment.Id"
                          class="comment-delete-form">

                        <button type="submit" class="comment-delete-btn">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </form>
                }

                <!-- Comment header -->
                <div class="comment-header">
                    <img src="https://ui-avatars.com/api/?name=@comment.User.UserName&background=EB9788&color=ffffff&size=64"
                         class="comment-avatar" />

                    <span class="comment-user">@comment.User.UserName</span>
                    <span class="comment-date">@comment.CreatedAt.ToShortDateString()</span>
                </div>

                <!-- Comment text -->
                <p class="comment-text">@Html.Raw(comment.Content)</p>
            </div>
        }
    </div>
    </div>  
    
    <div class="gallery-box section-box">
        <h2 class="section-title gallery-title">
            <i class="fa-solid fa-images gallery-icon"></i>
            Gallery
        </h2>

        <div class="gallery-top-line"></div>

        <div class="gallery-row">
            @foreach (var img in Model.GalleryImages)
            {
                <img src="@img.ImagePath" alt="Recipe image" class="gallery-img" />
            }
        </div>

        <div class="gallery-bottom-line"></div>
    </div>
    
    <div class="add-comment-box section-box">
        <h2 class="section-title comment-title">
            <i class="fa-solid fa-comment-dots comment-icon"></i>
            Add a Comment
        </h2>

        <form asp-controller="Comment" asp-action="AddComment" method="post">
            <input type="hidden" name="recipeId" value="@Model.Id" />

            <textarea name="text" class="comment-textarea" placeholder="Write your comment here..."></textarea>

            <button type="submit" class="comment-submit-btn">
                <i class="fa-solid fa-paper-plane"></i> Submit
            </button>
        </form>
    </div>
    
    <div class="back-btn-wrapper">
        <a asp-action="Index" class="back-btn">
            <i class="fa-solid fa-arrow-left"></i>
            Back to list
        </a>
    </div>

</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    
    <!-- Standard Bootstrap modal for confirming deletion -->
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 14px;">

            <div class="modal-header" style="background:#EB9788; color:white;">
                <h5 class="modal-title">Confirm Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" style="font-size:1.2rem;">
                Are you sure you want to delete <strong>@Model.Title</strong>?
            </div>

            <div class="modal-footer">
                <form method="post" asp-action="Delete">
                    <input type="hidden" name="id" value="@Model.Id"/>
                    <button type="submit" class="btn btn-danger">Yes, delete</button>
                </form>

                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    const likeBtn = document.getElementById("likeBtn");

    likeBtn.addEventListener("click", function () {
        fetch('/Recipes/Like/@Model.Id', {
            method: 'POST'
        })
        .then(response => {
            if (!response.ok) {
                alert("You must be logged in to like recipes.");
                return;
            }
            return response.json();
        })
        .then(data => {
            if (!data) return;

            //Update like count
            document.getElementById("likeCount").textContent = data.likes;

            //Update heart icon
            const heart = document.getElementById("heartIcon");

            if (data.liked) {
                heart.classList.remove("fa-regular");
                heart.classList.add("fa-solid");
                likeBtn.classList.add("liked");
            } else {
                heart.classList.remove("fa-solid");
                heart.classList.add("fa-regular");
                likeBtn.classList.remove("liked");
            }
        });
    });
</script>